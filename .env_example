# Copy this file to ".env" and fill in your own values:
#   cp .env_example .env
# The .env file is gitignored and never committed.

# ── LinkedIn (required when JOB_SITE="linkedin") ─────────────────────────────
linkedin_email="your_linkedin_email@example.com"
linkedin_password="your_linkedin_password"

# ── Indeed (only needed when JOB_SITE="indeed") ──────────────────────────────
indeed_email="your_indeed_email@example.com"

# ── LLM provider key (required) ──────────────────────────────────────────────
# This is the API key for whatever LLM_MODEL_TYPE you set in config/app_config.py
# (OpenRouter, Gemini, OpenAI, Claude, DeepSeek, Ollama, ...).
llm_api_key="your_llm_api_key"

# Optional: separate key/provider for the off-site (Non-Easy-Apply) browser agent.
# DeepSeek can't drive that agent, so set this to e.g. a Gemini/OpenAI key.
# Falls back to llm_api_key if left blank.
apply_agent_api_key=""

# Optional: proxy and custom base URL for LLM requests (e.g. local Ollama server).
llm_proxy=""
llm_api_url=""

# ── Telegram reports/errors (all optional) ───────────────────────────────────
# Leave blank to disable. The bot runs fine without Telegram.
tg_token=""
tg_chat_id="@name_of_your_chat"
tg_err_topic_id=""
tg_report_topic_id=""
# Only needed for the LinkedIn Messages Manager (telethon):
tg_api_id=""
tg_api_hash=""
